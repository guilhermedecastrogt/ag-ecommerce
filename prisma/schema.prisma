generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  createdAt DateTime @default(now())
}

model Order {
  id              Int         @id @default(autoincrement())
  userId          Int
  status          String      @default("PENDING")
  subTotal        Float
  shippingFee     Float       @default(0)
  discount        Float       @default(0)
  total           Float
  addressSnapshot String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime
  OrderItem       OrderItem[]
}

model KnownUser {
  id        Int      @id
  name      String
  email     String   @unique
  createdAt DateTime
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  slug     String    @unique
  products Product[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  price       Float
  stock       Int      @default(0)
  description String   @db.Text
  imageUrl    String
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuthUser {
  id           Int              @id @default(autoincrement())
  email        String           @unique
  passwordHash String
  status       String           @default("ACTIVE")
  role         String           @default("USER")
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  sessions     RefreshSession[]
}

model RefreshSession {
  id        Int       @id @default(autoincrement())
  jti       String    @unique
  userId    Int
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      AuthUser  @relation(fields: [userId], references: [id])

  @@index([userId], map: "RefreshSession_userId_fkey")
}

model MelhorEnvioToken {
  id           Int      @id @default(autoincrement())
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}

model Category {
  id      Int       @id @default(autoincrement())
  name    String
  slug    String    @unique
  Product Product[]
}

model OrderItem {
  id        Int    @id @default(autoincrement())
  orderId   Int
  productId String
  name      String
  price     Float
  quantity  Int
  Order     Order  @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  price       Float
  stock       Int      @default(0)
  description String   @db.Text
  imageUrl    String
  categoryId  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime
  Category    Category @relation(fields: [categoryId], references: [id])

  @@index([categoryId], map: "Product_categoryId_fkey")
}

model ShipmentLabel {
  id           Int      @id @default(autoincrement())
  orderId      Int      @unique
  cartItemId   String
  serviceId    Int
  serviceName  String
  trackingCode String?
  labelUrl     String?  @db.Text
  price        String?
  status       String   @default("PURCHASED")
  purchasedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}

model MelhorEnvioToken {
  id           Int      @id @default(autoincrement())
  accessToken  String   @db.Text
  refreshToken String   @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ShipmentLabel {
  id           Int      @id @default(autoincrement())
  orderId      Int      @unique
  cartItemId   String   // ID do item no carrinho do Melhor Envio
  serviceId    Int
  serviceName  String
  trackingCode String?
  labelUrl     String?  @db.Text
  price        String?  // valor cobrado (string como retornado pela API)
  status       String   @default("PURCHASED") // PURCHASED, CANCELLED
  purchasedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

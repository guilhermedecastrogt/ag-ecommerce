# ─── Banco de Dados ──────────────────────────────────────────────────────────
DATABASE_URL=mysql://root:CHANGE_ME@localhost:3306/study_ms

# ─── JWT (obrigatório — nunca use o valor de exemplo em produção) ─────────────
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_SECRET_HERE

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BROKER=kafka:9092

# ─── CORS — origens permitidas (vírgula separado) ─────────────────────────────
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# ─── Admin seed ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@aguiadiesel.com.br
ADMIN_PASSWORD=admin@123
ADMIN_NAME=Administrador

# ─── Logging ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Portas de Health (microserviços) ────────────────────────────────────────
USERS_HEALTH_PORT=4011
AUTH_HEALTH_PORT=4013
ORDERS_HEALTH_PORT=4012
PRODUCT_HEALTH_PORT=4014
